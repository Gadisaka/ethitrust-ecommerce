# MongoDB
MONGO_URI=

# Auth
JWT_SECRET=

# Ethitrust Escrow
ETHITRUST_API_KEY=
ETHITRUST_API_KEY_HEADER=X-API-KEY
ETHITRUST_WEBHOOK_SECRET=
ETHITRUST_BASE_URL=https://api.ethitrust.me
ETHITRUST_TIMEOUT_MS=30000
ETHITRUST_MAX_RETRIES=2
ENABLE_ESCROW=true
ETHITRUST_SELLER_EMAIL=
ETHITRUST_INSPECTION_PERIOD=72
ESCROW_SYNC_INTERVAL_MS=600000
ESCROW_SYNC_STALE_MS=900000

# Legacy alias (optional)
# ETHITRUST_API_BASE_URL=https://api.ethitrust.me

# CORS (comma-separated extra origins)
# CORS_ORIGINS=

# Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Logging
# LOG_LEVEL=info
